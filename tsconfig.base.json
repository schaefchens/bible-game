{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "moduleDetection": "force",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@bible/engine": ["./packages/engine/src/index.ts"],
      "@bible/content": ["./packages/content/src/index.ts"],
      "@bible/i18n": ["./packages/i18n/src/index.ts"],
      "@bible/persistence": ["./packages/persistence/src/index.ts"],
      "@bible/assets": ["./packages/assets/src/index.ts"]
    }
  }
}
